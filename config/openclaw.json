{
  "gateway": {
    "port": 18789,
    "bind": "0.0.0.0",
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "reload": "hybrid"
  },

  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "${OLLAMA_BASE_URL}",
        "apiKey": "${OLLAMA_API_KEY}",
        "api": "ollama",
        "models": [
          {
            "id": "qwen3-coder:latest",
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "llama3.1:8b",
            "contextWindow": 131072,
            "maxTokens": 4096
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary":   "ollama/qwen3-coder:latest",
        "fallbacks": [
          "ollama/llama3.1:8b"
        ]
      },
      "workspace": "${OPENCLAW_HOME}/workspace",
      "sandbox":   "non-main"
    }
  },

  "env": {
    "shellEnv": false,
    "vars": {}
  }
}
