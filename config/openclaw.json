{
  "gateway": {
    "port": 18789,
    "mode": "local",
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "reload": {}
  },

  "models": {
    "providers": {
      "gemini": {
        "apiKey": "${GEMINI_API_KEY}"
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary":   "gemini/gemini-2.0-flash",
        "fallbacks": [
          "gemini/gemini-1.5-flash"
        ]
      },
      "workspace": "${OPENCLAW_HOME}/workspace",
      "sandbox":   {}
    }
  },

  "env": {
    "shellEnv": {},
    "vars": {}
  }
}
