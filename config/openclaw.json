{
  "gateway": {
    "port": 18789,
    "mode": "local",
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "reload": {}
  },

  "models": {
    "providers": {
      "ollama": {
        "apiKey": "ollama",
        "baseUrl": "http://ollama:11434",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "kimi-k2.5:cloud",
            "name": "Kimi K2.5 (Cloud)",
            "api": "anthropic-messages",
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 16384
          },
          {
            "id": "glm-5:cloud",
            "name": "GLM-5 (Cloud)",
            "api": "anthropic-messages",
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 16384
          },
          {
            "id": "qwen3:30b-a3b",
            "name": "Qwen3 30B (Local)",
            "api": "anthropic-messages",
            "input": ["text"],
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "qwen2.5-coder:7b",
            "name": "Qwen2.5 Coder 7B (Local)",
            "api": "anthropic-messages",
            "input": ["text"],
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary":   "ollama/qwen2.5-coder:7b",
        "fallbacks": []
      },
      "workspace": "${OPENCLAW_HOME}/workspace",
      "sandbox":   {}
    }
  },

  "channels": {
    "telegram": {
      "botToken":      "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy":      "pairing",
      "streaming":     "partial",
      "reactionLevel": "ack",
      "ackReaction":   "👀"
    }
  }
}
