# ═══════════════════════════════════════════════════════════════════════════════
# openclaw-docker-agent — Environment Configuration
#
# Copy this file to .env on your VPS and fill in the required values.
#   cp .env.example .env
#
# .env is gitignored — never commit it.
# ═══════════════════════════════════════════════════════════════════════════════

# ── OpenClaw ─────────────────────────────────────────────────────────────────
# npm package version — pin for reproducibility (e.g. 2026.2.26) or use latest
OPENCLAW_VERSION=latest

# Gateway API token — minimum 32 characters
# Generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME

# ── Ollama ───────────────────────────────────────────────────────────────────
# Any non-empty value activates the Ollama provider
OLLAMA_API_KEY=ollama-local

# Ollama endpoint — reached via SSH reverse tunnel from your local machine.
# host.docker.internal resolves to the VPS host from inside Docker containers.
# The SSH tunnel binds Ollama to VPS port 11434, making this URL work.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Caddy Basic Auth ──────────────────────────────────────────────────────────
# Username shown at the web UI login prompt
CADDY_AUTH_USER=agent

# bcrypt hash of your chosen password
# Generate on the VPS after first make up: make gen-auth PASSWORD=your_password
# Then paste the $2a$... output here.
CADDY_AUTH_HASH=REPLACE_ME
