# openclaw-docker-agent — Environment Configuration
#
# Copy this file to .env and fill in the required values, or run:
#   python3 scripts/gen-env.py
#
# .env is gitignored — never commit it.

# --- OpenClaw ---
# npm package version — pin for reproducibility (e.g. 2026.2.26) or use latest
OPENCLAW_VERSION=latest

# Gateway API token — minimum 32 characters
# Generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME

# --- Telegram ---
# Bot token from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=REPLACE_ME

# --- Paths (machine-specific) ---
# Absolute path to this repo ON THE HOST (not inside the container).
# On Linux: /home/youruser/openclaw-docker-agent
REPO_HOST_PATH=REPLACE_ME

# Docker group GID — allows the container to use /var/run/docker.sock.
# Find yours: getent group docker | cut -d: -f3
DOCKER_GID=999

# --- Ollama (Windows LAN machine) ---
# Full URL to the Ollama instance running on your Windows machine.
# Run scripts/windows/setup-ollama.ps1 on Windows to configure Ollama for LAN access.
# Then run scripts/network/test-ollama.sh from the Linux machine to verify connectivity.
# Example: http://192.168.1.100:11434
OLLAMA_HOST=http://REPLACE_ME:11434

# Default model for coding agents (must be pulled on the Windows machine first).
# Run on Windows: ollama pull qwen2.5-coder:7b
OLLAMA_MODEL=qwen2.5-coder:7b

# --- Claude Pro agents (optional) ---
# Only needed if you want coding agents to use your Claude Pro subscription via API key.
# Prefer OAuth credential injection via Telegram instead (see CLAUDE.md).
# ANTHROPIC_API_KEY=<from console.anthropic.com>
