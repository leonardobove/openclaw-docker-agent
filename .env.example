# openclaw-docker-agent - Environment Configuration
#
# Copy this file to .env and fill in the required values:
#   python3 scripts/gen-env.py
#
# .env is gitignored - never commit it.

# --- OpenClaw ---
# npm package version - pin for reproducibility (e.g. 2026.2.26) or use latest
OPENCLAW_VERSION=latest

# Gateway API token - minimum 32 characters
# Generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME

# --- Google Gemini ---
# Free API key from https://aistudio.google.com/apikey
# No credit card required. Used by the coding agent as its LLM.
GEMINI_API_KEY=REPLACE_ME

# --- Caddy Basic Auth ---
# Username shown at the web UI login prompt
CADDY_AUTH_USER=agent

# bcrypt hash of your chosen password
# Generate: python3 scripts/gen-env.py
CADDY_AUTH_HASH=REPLACE_ME
